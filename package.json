{
  "name": "codexh-desktop-agent",
  "private": true,
  "version": "2.1.3",
  "description": "A desktop coding and workflow agent inspired by the codexh design document.",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "check:runtime": "node scripts/check-runtime.mjs",
    "predev": "node scripts/check-runtime.mjs",
    "dev": "electron-vite dev --config apps/desktop/electron.vite.config.ts",
    "prebuild": "node scripts/check-runtime.mjs",
    "build": "electron-vite build --config apps/desktop/electron.vite.config.ts",
    "generate:icon": "node scripts/generate-app-icon.mjs",
    "stage:skills": "node scripts/stage-bundled-skills.mjs",
    "fetch:grammars": "node scripts/fetch-tree-sitter-grammars.mjs",
    "prepare:windows-icon": "node scripts/prepare-windows-icon-tool.mjs",
    "package:win": "pnpm generate:icon && pnpm stage:skills && pnpm fetch:grammars && pnpm prepare:windows-icon && pnpm build && electron-builder --win nsis",
    "preview": "electron-vite preview --config apps/desktop/electron.vite.config.ts",
    "typecheck": "tsc --project apps/desktop/tsconfig.json --noEmit",
    "pretest": "node scripts/check-runtime.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.2.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "11.11.1",
    "iconv-lite": "^0.7.3",
    "jsonrepair": "^3.15.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "openai": "^6.45.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tree-sitter-wasms": "0.1.13",
    "web-tree-sitter": "0.25.10",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.0",
    "electron-builder": "24.13.3",
    "electron-vite": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.codexh.desktop",
    "productName": "CodeXH",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "afterPack": "./scripts/after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/seed-skills",
        "to": "seed-skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "assets/tree-sitter-grammars",
        "to": "tree-sitter-grammars",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "CodeXH-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.11.0"
  }
}
